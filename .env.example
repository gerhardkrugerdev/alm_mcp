# Helix ALM REST API Connection
HELIX_ALM_URL=https://localhost:8443/helix-alm/api/v0/
HELIX_ALM_USER=administrator
HELIX_ALM_PASSWORD=yourpassword

# OR use API Key authentication (recommended)
# HELIX_ALM_API_KEY=your-api-key
# HELIX_ALM_API_SECRET=your-api-secret

# SSL verification (set to "true" if using a trusted certificate)
HELIX_ALM_SSL_VERIFY=false

# Azure DevOps Integration (for pulling test results from CI/CD pipelines)
AZDO_ORG=your-organization
AZDO_PROJECT=your-project
AZDO_PAT=your-personal-access-token
